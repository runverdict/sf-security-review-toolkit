<?xml version="1.0" encoding="UTF-8"?>
<!--
  Authored source-scanner fixture for harness/ingest-scanner-findings.mjs
  (view-modify-all-data adapter). Synthetic toolkit test data — NOT a partner artifact.
  NEGATIVE (must yield 0 findings) — exercises every precision guard:
    1. ViewSetup enabled=true        -> NOT flagged (a benign, non-sharing-bypass permission).
    2. ViewAllUsers enabled=true     -> NOT flagged (name EXACTNESS — a ViewAll* prefixed
                                        permission is not ViewAllData).
    3. ViewAllData enabled=false     -> NOT flagged (the grant must be ENABLED; API v29.0+
                                        serializes only enabled permissions, but a rare
                                        explicit false row must stay clean).
    4. The <description> below names ViewAllData in prose -> NOT flagged (element-scoped:
       only a <userPermissions> block's <name> is read, never free text).
-->
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Least Priv</label>
    <description>Setup visibility only; ViewAllData is deliberately not granted to this persona.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <userPermissions>
        <enabled>true</enabled>
        <name>ViewSetup</name>
    </userPermissions>
    <userPermissions>
        <enabled>true</enabled>
        <name>ViewAllUsers</name>
    </userPermissions>
    <userPermissions>
        <enabled>false</enabled>
        <name>ViewAllData</name>
    </userPermissions>
</PermissionSet>
